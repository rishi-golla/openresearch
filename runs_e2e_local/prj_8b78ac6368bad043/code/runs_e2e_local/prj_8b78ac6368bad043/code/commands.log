# =============================================================================
# Commands to reproduce Schulman et al. 2017 — PPO
# Project: prj_8b78ac6368bad043
# Suite: CleanRL-style PyTorch PPO, MuJoCo -v4 + Atari NoFrameskip-v4
# =============================================================================

# ---- 0. Build the Docker image ----------------------------------------------
docker build -t ppo-repro:latest .

# ---- 1. Smoke test (~2 min on CPU) ------------------------------------------
docker run --rm -e MUJOCO_GL=egl -v $(pwd)/results:/workspace/code/results ppo-repro:latest \
    python train.py --config config.json --smoke

# Or directly:
python ppo_continuous_action.py --env-id HalfCheetah-v4 --total-timesteps 50000 \
    --learning-rate 3e-4 --num-envs 1 --num-steps 2048 --num-minibatches 32 \
    --update-epochs 10 --clip-coef 0.2 --gamma 0.99 --gae-lambda 0.95 --seed 1 --track False

python ppo_atari.py --env-id BreakoutNoFrameskip-v4 --total-timesteps 50000 \
    --num-envs 8 --num-steps 128 --num-minibatches 4 --update-epochs 3 \
    --clip-coef 0.1 --anneal-lr True --seed 1 --track False

# ---- 2. Phase 1 — MuJoCo full sweep (21 runs, ~5–7h on CPU) -----------------
# Driven via train.py:
python train.py --config config.json --suite mujoco

# Or per-env (parallelizable):
for ENV in HalfCheetah-v4 Hopper-v4 InvertedDoublePendulum-v4 InvertedPendulum-v4 \
           Reacher-v4 Swimmer-v4 Walker2d-v4; do
  for SEED in 1 2 3; do
    python ppo_continuous_action.py \
        --env-id $ENV --seed $SEED \
        --total-timesteps 1000000 \
        --learning-rate 3e-4 --num-envs 1 --num-steps 2048 \
        --num-minibatches 32 --update-epochs 10 \
        --clip-coef 0.2 --gamma 0.99 --gae-lambda 0.95 \
        --ent-coef 0.0 --vf-coef 0.5 --max-grad-norm 0.5 \
        --output-dir results/mujoco --track False
  done
done

# ---- 3. Phase 2 — Atari budgeted 5-game subset (15 runs) --------------------
python train.py --config config.json --suite atari

# Or per-game:
for GAME in BreakoutNoFrameskip-v4 BeamRiderNoFrameskip-v4 PongNoFrameskip-v4 \
            QbertNoFrameskip-v4 SpaceInvadersNoFrameskip-v4; do
  for SEED in 1 2 3; do
    python ppo_atari.py \
        --env-id $GAME --seed $SEED \
        --total-timesteps 10000000 \
        --learning-rate 2.5e-4 --num-envs 8 --num-steps 128 \
        --num-minibatches 4 --update-epochs 4 \
        --clip-coef 0.1 --anneal-lr True \
        --ent-coef 0.01 --vf-coef 0.5 --max-grad-norm 0.5 \
        --gamma 0.99 --gae-lambda 0.95 \
        --output-dir results/atari --track False
  done
done

# ---- 4. Aggregation & metrics ----------------------------------------------
python evaluate.py --results-dir results
# Produces:
#   results/mujoco/normalized_scores.json
#   results/mujoco/avg_normalized_score_scalar.txt
#   results/mujoco/mujoco_summary_table.csv
#   results/atari/atari_summary_table.csv
#   results/atari/games_won_alltraining.json
#   results/atari/games_won_last100.json
#   results/metrics.json

# ---- 5. End-to-end full sweep + eval in one shot ---------------------------
python train.py --config config.json --suite all
