# ============================================================================
# Minimal local-dev .env (everything else in this file is optional):
#
#   OPENRESEARCH_DEFAULT_SANDBOX=local   # no Docker daemon / RunPod needed
#   + exactly ONE root-model credential (OPENAI_API_KEY, a credited
#     ANTHROPIC_API_KEY, OPENROUTER_API_KEY or FEATHERLESS_API_KEY) — or NO
#     key at all with `--model claude-oauth` after `claude login`.
#
# The backend boots with no .env at all (SQLite default, demo gate disabled).
# Vars here are read by backend/config.py (pydantic-settings). NOTE: real
# shell exports WIN over this file — see the BUG-LR-014 gotcha in CLAUDE.md.
# ============================================================================

OPENRESEARCH_ENVIRONMENT=development
OPENRESEARCH_DATABASE_URL=sqlite:///openresearch.db
OPENRESEARCH_LLM_PROVIDER=anthropic
# Force the orchestrator's provider chain to [primary] only — no
# cross-provider fallback. Set to "true" when your shell env has a
# leftover/invalid OPENAI_API_KEY (e.g. an sk-svcacct-* service-account
# key without chat-completions scope) that would surface a misleading
# 401 if anthropic blips. Default false preserves existing fallback
# behaviour for users with two valid keys.
OPENRESEARCH_PROVIDER_FALLBACK_DISABLED=false
OPENRESEARCH_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
OPENRESEARCH_ANTHROPIC_REASONING_MODEL=claude-opus-4-7
OPENRESEARCH_OPENAI_DEFAULT_MODEL=gpt-4o
OPENRESEARCH_OPENAI_REASONING_MODEL=o4-mini

# Required when running SDK mode with the matching provider.
#
# ANTHROPIC_API_KEY can be left EMPTY for local testing if the `claude` CLI
# (Claude Code) is installed and logged in on this machine. The pipeline uses
# `claude-agent-sdk`, which falls back to spawning the `claude` CLI subprocess
# and inheriting its auth (your Claude Code subscription). This is the
# preferred path for local development — no per-token billing, and the full
# pipeline runs against your existing subscription.
# Set this key explicitly only when: (a) running in CI / a container where
# `claude` CLI is not available, (b) you hit subscription rate limits and
# want to switch to API-key billing, or (c) the subprocess auth path is
# unreliable in your environment.
#
# WARNING (learned 2026-05-22): if you set this to a key whose Anthropic
# *API account* has no credits, `claude-agent-sdk` tries the key first,
# hits 400 "credit balance too low", and DOES NOT fall back to OAuth —
# every reproduction dies at the first Sonnet sub-call with cost_usd=0.0,
# verdict=failed. The Anthropic API balance and the Claude Code
# subscription are billed separately; `claude --print "ping"` returning
# `pong` proves only the subscription works, the API key needs its own
# credits. Either leave this empty (let SDK use OAuth) OR set it to a
# credited key — never set it to a no-credit key.
#
# Note: for the RLM root model (`--mode rlm`), `--model claude` requires
# this key to be set + credited, while `--model claude-oauth` uses the
# `claude` CLI subscription with no API key at all (zero-cost path, subject
# to subscription rate limits). For local dev prefer `--model gpt-5`
# (OPENAI_API_KEY), `--model qwen3-coder-featherless` (FEATHERLESS_API_KEY),
# or `--model claude-oauth`, and let `claude-agent-sdk` handle Sonnet
# sub-agents via OAuth.
#
# Note (2026-05-23, macOS): the OAuth fallback now works on modern macOS too.
# Claude Code stores credentials in the Keychain (not in
# ~/.claude/.credentials.json), and factory.py:_has_claude_subscription_oauth
# probes both backends. Before this fix the SDK silently failed on macOS
# even with a working `claude login` — leaving this empty made the SDK
# return "no agent runtime could be resolved" on every reproduction.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: accepted by the OpenAI SDK when using admin-scoped credentials.
OPENAI_ADMIN_KEY=

# RLM root model selection + the remaining root credentials (CLAUDE.md "RLM
# auth"). OPENRESEARCH_RLM_ROOT_MODEL ∈ gpt-5 | qwen3-coder | kimi-k2.5 |
# claude | claude-oauth | qwen3-coder-featherless | azure. Empty = auto
# (GPT-5 when OPENAI_API_KEY is set; claude-oauth when no keys but `claude
# login` is active).
OPENRESEARCH_RLM_ROOT_MODEL=
# For --model qwen3-coder / kimi-k2.5 (served via OpenRouter slugs).
OPENROUTER_API_KEY=
# For --model qwen3-coder-featherless (cheapest hosted root).
FEATHERLESS_API_KEY=

# Optional Codex CLI repo-editing repair subagent. Default off. This route is
# only exposed as the gated RLM codex_repair primitive and is not used for
# rlm_query, paper navigation, rubric judgment, or final reports.
OPENRESEARCH_CODEX_SUBAGENT=0
OPENRESEARCH_CODEX_TIMEOUT_S=900
OPENRESEARCH_CODEX_MAX_CALLS_PER_RUN=3
OPENRESEARCH_CODEX_MAX_OUTPUT_CHARS=12000
OPENRESEARCH_CODEX_PROFILE=openresearch-readwrite
OPENRESEARCH_CODEX_ALLOWED_TASKS=implementation_repair,test_debugging,dockerfile_repair,requirements_repair

# Optional: force the dashboard subprocess to use a specific interpreter.
OPENRESEARCH_PYTHON_BIN=

# Optional: lab API default sandbox (one of auto|local|docker|runpod).
# The code default is runpod, which needs RunPod credentials + an SSH key
# (no local Docker — the pod boots its own image). For a first run on a
# clean machine use `local` (host subprocesses, no remote GPU) and switch
# later. Only docker/auto need a local Docker daemon.
OPENRESEARCH_DEFAULT_SANDBOX=local

# Optional: hard override for every run's sandbox. Empty honors each request.
# Set to docker/local only on deployments that must forbid other sandboxes.
OPENRESEARCH_FORCE_SANDBOX=

# Optional (LOCAL sandbox only): the harness OWNS a coherent cu121 torch core. It
# installs torch/torchvision/torchaudio from this index FIRST and strips the agent's
# conflicting re-pin from requirements.txt (env_pin) — the fix for the 2026-06-07
# All-Conv-Net collapse where `torch==2.2.0` downgraded the build and libcupti failed
# to load. Override the index for a different driver, or set it EMPTY to disable the
# pin entirely (raw requirements.txt). To let a paper install a non-cu121/older torch
# without disabling the index, set OPENRESEARCH_DISABLE_ENV_PIN=1 instead.
OPENRESEARCH_LOCAL_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
OPENRESEARCH_DISABLE_ENV_PIN=

# Optional (LOCAL sandbox only): run_experiment stall window in seconds (default
# 3600 = 60 min, deliberately generous; 0 disables). If a run_experiment produces
# no stdout/stderr line, no checkpoint/metrics.json mtime bump, no GPU-util, AND no
# CPU-util for this whole window, it is killed as `exec_stalled` (a genuine hang) —
# distinct from the hard wall-clock budget cap (`exec_timeout`). Completed work is
# still finalized (on-disk partial metrics.json is scored), never zeroed.
OPENRESEARCH_EXPERIMENT_STALL_S=3600

# Optional (LOCAL sandbox only): GPU-util liveness signal for the stall check above.
# Default on (1); set 0 to disable it (e.g. when `nvidia-smi` is unavailable). CPU-util,
# output lines, and checkpoint/metrics.json mtime still gate the stall when this is off.
OPENRESEARCH_EXPERIMENT_GPU_LIVENESS=1

# Optional: remote GPU execution via `--sandbox runpod`.
# RUNPOD_API_KEY is also accepted if you already use the Runpod CLI convention.
OPENRESEARCH_RUNPOD_API_KEY=
# Default (code, config.py): the -devel- image (~18 GB) — its CUDA dev
# headers are REQUIRED by deps that JIT-compile (bitsandbytes, flash-attn,
# deepspeed); the lighter -runtime- image (~4 GB) silently broke those and
# was reverted (commit 88c45b0). Uncomment with a -runtime- tag ONLY when a
# paper needs no CUDA JIT. Leave commented to use the safe code default.
#OPENRESEARCH_RUNPOD_IMAGE=runpod/pytorch:2.1.0-py3.10-cuda11.8.0-devel-ubuntu22.04
# Quoted: values with spaces break shells that `source` a .env (python-dotenv
# accepts either form).
OPENRESEARCH_RUNPOD_GPU_TYPE="NVIDIA GeForce RTX 4090"
OPENRESEARCH_RUNPOD_GPU_COUNT=1
OPENRESEARCH_RUNPOD_CLOUD_TYPE=SECURE
OPENRESEARCH_RUNPOD_CONTAINER_DISK_GB=50
OPENRESEARCH_RUNPOD_VOLUME_GB=20
OPENRESEARCH_RUNPOD_VOLUME_MOUNT_PATH=/workspace
OPENRESEARCH_RUNPOD_NETWORK_VOLUME_ID=
OPENRESEARCH_RUNPOD_DATA_CENTER_IDS=
OPENRESEARCH_RUNPOD_SSH_KEY_PATH=
OPENRESEARCH_RUNPOD_SSH_PUBLIC_KEY=
# Whether to delete the Runpod pod after each pipeline run.
#   true   (default)  — ephemeral runs, no leaked pod cost. Each pipeline
#                       boots a fresh pod and tears it down.
#   false             — persistent workflow. Pods survive across runs so
#                       you can attach back via SSH, share with a coworker
#                       on the same Runpod account, or amortise boot time.
#                       YOU are responsible for stopping/destroying these
#                       pods in the Runpod dashboard when you're done.
OPENRESEARCH_RUNPOD_DELETE_ON_DESTROY=true
OPENRESEARCH_RUNPOD_BOOTSTRAP_COMMAND=

# Optional pod-time budget cap (seconds). When set, each RunPod exec() call
# checks cumulative pod CPU-seconds against this limit; once exceeded, the
# next exec() raises BudgetExhaustedError and the run stops cleanly instead
# of running indefinitely. Equivalent to --max-pod-seconds on the CLI.
# Leave empty (or unset) to disable the cap.
OPENRESEARCH_MAX_POD_SECONDS=

# Optional persistent pod. When set, the backend attaches to this pod
# instead of creating a fresh one per pipeline run. The pod is NEVER
# deleted (the _owned_pod_ids allowlist enforces this). If the configured
# pod is missing or stopped, the backend creates a new persistent pod and
# logs the new id at WARNING level — update this var with that id to
# reuse it on the next run. Leave empty for per-run create+destroy.
OPENRESEARCH_RUNPOD_POD_ID=

# Apify ArXiv MCP server (https://github.com/apify/actor-arxiv-mcp-server).
# When APIFY_API_TOKEN is set, the Claude agent runtime registers the
# Apify-hosted SSE endpoint as an MCP server named "apify-arxiv" and
# exposes its tools (paper search / paper access / paper listing) to
# the agent ids in OPENRESEARCH_APIFY_ARXIV_ENABLED_AGENTS. Get a token at
# https://console.apify.com/account/integrations. Leave empty to skip
# MCP wiring entirely (no extra latency, no failed cold-start handshake).
APIFY_API_TOKEN=
OPENRESEARCH_APIFY_ARXIV_MCP_URL=https://jakub-kopecky--arxiv-mcp-server.apify.actor/sse
OPENRESEARCH_APIFY_ARXIV_ENABLED_AGENTS=artifact-discovery,paper-understanding

# Azure OpenAI (production target — see W2c in docs/archive/uiprogress.md):
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Azure AKS GPU sandbox (--sandbox azure) ---------------------------------
# Dispatches each training cell as a Kubernetes Job on an AKS cluster with a
# scale-to-zero A100 pool. Provisioning + full run steps:
#   docs/guides/azure-kubernetes-gpu-setup.md
# Auth is via `az login` (Workload Identity) — no storage keys here.
# Leave unset unless you actually run --sandbox azure.
#
# OPENRESEARCH_AZURE_RESOURCE_GROUP=         # AKS cluster resource group
# OPENRESEARCH_AZURE_AKS_CLUSTER=            # AKS cluster name
# OPENRESEARCH_AZURE_STORAGE_ACCOUNT=        # Blob + Files storage account
# OPENRESEARCH_AZURE_ACR_LOGIN_SERVER=       # e.g. myacr.azurecr.io
# OPENRESEARCH_AZURE_BASE_IMAGE=             # PINNED cell image tag (never :latest)
# Defaults below match the Helm chart — override only if you changed them:
# OPENRESEARCH_AZURE_NAMESPACE=reprolab
# OPENRESEARCH_AZURE_SERVICE_ACCOUNT=reprolab-sa
# OPENRESEARCH_AZURE_NODE_POOL_NAME=gpua100
# OPENRESEARCH_AZURE_BLOB_CONTAINER=reprolab-artifacts
# OPENRESEARCH_AZURE_FILES_SHARE=reprolab-cache
# OPENRESEARCH_AZURE_GPU_USD_PER_HOUR=3.67   # for budget tracking; set your rate
# ----------------------------------------------------------------------------
# Operator-facing feature flags & knobs (all optional; commented = code
# default applies; full semantics in CLAUDE.md "Feature flags"). Deep
# internals are deliberately NOT listed here — see backend/config.py.
# ----------------------------------------------------------------------------
# Demo gate: when set, run-start endpoints require the matching
# X-Demo-Secret header and the frontend shows the /unlock wall. Empty (the
# default) disables the gate — local-dev behavior, not a bug.
#OPENRESEARCH_DEMO_SECRET=
# Frontend server-side proxy target (defaults to http://127.0.0.1:8000;
# set only when the backend runs elsewhere).
#OPENRESEARCH_BACKEND_URL=http://127.0.0.1:8000
# PEEK-lite intra-run context map (default off).
#OPENRESEARCH_CONTEXT_MAP=on
# MUSE-lite per-paper negative lessons (default off).
#OPENRESEARCH_NEGATIVE_LESSONS=1
# gpt-5-mini navigation accelerator route (default off). Keep SCOPE=navigation.
#OPENRESEARCH_ACCELERATOR=endpoint
#OPENRESEARCH_ACCELERATOR_BASE_URL=https://api.openai.com/v1
#OPENRESEARCH_ACCELERATOR_MODEL=gpt-5-mini
#OPENRESEARCH_ACCELERATOR_SCOPE=navigation
# Endpoint credential; for api.openai.com it falls back to OPENAI_API_KEY.
#OPENRESEARCH_ACCELERATOR_API_KEY=
#OPENRESEARCH_SUBRLM_OPENAI_TIMEOUT_S=120
# Dynamic GPU selection (default ON; both spellings accepted).
#OPENRESEARCH_DYNAMIC_GPU_ENABLED=true
#OPENRESEARCH_FORCE_SINGLE_GPU=true
#OPENRESEARCH_MAX_GPU_USD_PER_HOUR=10.0
#OPENRESEARCH_MAX_RUN_GPU_USD=10.0
# Forced-iteration floor before FINAL_VAR is accepted (0 disables).
#OPENRESEARCH_MIN_RUBRIC_ITERATIONS=2
# run_experiment free-disk preflight floor in GB (0 disables; default 15).
#OPENRESEARCH_DISK_FLOOR_GB=15
# Opt-in automatic runs/ retention: prune TERMINAL runs older than N days
# (hourly, honors .preserved). Unset/0 = off; manual: scripts/prune_runs.py.
#OPENRESEARCH_RUNS_RETENTION_DAYS=30