REPROLAB_ENVIRONMENT=development
REPROLAB_DATABASE_URL=sqlite:///reprolab.db
REPROLAB_LLM_PROVIDER=anthropic
REPROLAB_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
REPROLAB_ANTHROPIC_REASONING_MODEL=claude-opus-4-7
REPROLAB_OPENAI_DEFAULT_MODEL=gpt-4o
REPROLAB_OPENAI_REASONING_MODEL=o4-mini

# Required when running SDK mode with the matching provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: force the dashboard subprocess to use a specific interpreter.
REPROLAB_PYTHON_BIN=

# Optional: remote GPU execution via `--sandbox runpod`.
# RUNPOD_API_KEY is also accepted if you already use the Runpod CLI convention.
REPROLAB_RUNPOD_API_KEY=
REPROLAB_RUNPOD_IMAGE=runpod/pytorch:2.1.0-py3.10-cuda11.8.0-devel-ubuntu22.04
REPROLAB_RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 4090
REPROLAB_RUNPOD_GPU_COUNT=1
REPROLAB_RUNPOD_CLOUD_TYPE=SECURE
REPROLAB_RUNPOD_CONTAINER_DISK_GB=50
REPROLAB_RUNPOD_VOLUME_GB=20
REPROLAB_RUNPOD_VOLUME_MOUNT_PATH=/workspace
REPROLAB_RUNPOD_NETWORK_VOLUME_ID=
REPROLAB_RUNPOD_DATA_CENTER_IDS=
REPROLAB_RUNPOD_SSH_KEY_PATH=
REPROLAB_RUNPOD_SSH_PUBLIC_KEY=
REPROLAB_RUNPOD_DELETE_ON_DESTROY=true
REPROLAB_RUNPOD_BOOTSTRAP_COMMAND=
