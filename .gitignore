/node_modules/

# Local-only test logs and DB backups
_test_logs/
reprolab.db.offline_backup
reprolab.db-shm
reprolab.db-wal

# Sample input PDFs — keep paperbench1.pdf as the canonical FTRL fixture.
# Add ! exceptions if more named samples should be tracked.
/paperbench*.pdf
!/paperbench1.pdf

# Stray pip output written into repo root
/[0-9]*.[0-9]*.[0-9]*

# Stray npm lockfile written into repo root; the real lockfile is frontend/package-lock.json.
/package-lock.json

# Local planning prompts, ad-hoc screenshots, and corrupt DB recovery snapshots.
# Root-level PNGs are ad-hoc screenshots; intentional doc assets live in docs/.
/claude_plan_*.md
/claude_review_*.md
/codex_prompt*.md
/conflicts.md
/*.png
/reprolab.db.corrupt-*

