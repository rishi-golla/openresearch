# Local run outputs (anchored to repo root — must not match nested
# source paths like frontend/src/app/api/runs/ or frontend/src/lib/runs/
# or backend/services/runs/).
# Policy (2026-05-30): IGNORE the heavy run artifacts (per-run .venv/, code/,
# rlm_state/ checkpoints, weight caches, .heartbeat) but TRACK the small,
# high-value per-run diagnostic logs so results + failure trails live in git.
# Whitelist idiom: ignore everything under /runs/, then re-include the per-run
# dirs (so git descends ONE level — it never walks code/ or .venv/) plus the
# specific key logs.
/runs/**
!/runs/*/
!/runs/*/final_report.json
!/runs/*/final_report.md
!/runs/*/demo_status.json
!/runs/*/batch_child.log
!/runs/*/experiment_runs.jsonl
!/runs/*/cost_ledger.jsonl
!/runs/*/tokens_total.json
# (dashboard_events.jsonl is the full SSE firehose — can be large; track it
#  per-run on demand with `git add -f runs/<id>/dashboard_events.jsonl`.)
# Throwaway BES A1 SELECT-stability capture dirs — re-ignore wholesale (these
# override the per-run whitelist above) so the safe-capture wrapper's scratch
# runs never sweep their whitelisted JSON into a commit.
/runs/bes_a1_*/
runs/_archive/
# Launcher / per-run logs (OPENRESEARCH_RUNS_ROOT diagnostics, _no_runs_root, etc.)
/logs/
/logs

# Large binary archives never belong in git history (D2: a 6 MB bundle was
# committed by accident). Ship docs as markdown or release assets, not zips.
*.zip
/paper-repro-bes-docs/

# Windows artifacts
%APPDATA%/
*:Zone.Identifier

# Frontend build artifacts
frontend/tsconfig.tsbuildinfo

# Test runner output (Playwright traces, screenshots, JSON artifacts)
test-results/
frontend/test-results/
frontend/playwright-report/

# Repo-root /screenshots is produced by scripts/lab_screenshot_tail.mjs
# during E2E monitoring runs; outputs are ephemeral, do not commit.
/screenshots/

# Stray root-level node_modules (the real one is frontend/node_modules/)
/node_modules/

# Local-only test logs and DB backups
_test_logs/
openresearch.db.offline_backup
openresearch.db-shm
openresearch.db-wal
# Legacy DB name (pre-2026-06 rename) — kept because the backward-compat
# fallback in backend/config.py still uses an existing reprolab.db, so SQLite
# keeps producing these sibling files until the DB is migrated.
reprolab.db.offline_backup
reprolab.db-shm
reprolab.db-wal

# Sample input PDFs — keep paperbench1.pdf as the canonical FTRL fixture.
# Add ! exceptions if more named samples should be tracked.
/paperbench*.pdf
!/paperbench1.pdf

# Stray pip output written into repo root
/[0-9]*.[0-9]*.[0-9]*

# Stray npm lockfile written into repo root; the real lockfile is frontend/package-lock.json.
/package-lock.json

# Local planning prompts, ad-hoc screenshots, and corrupt DB recovery snapshots.
# Root-level PNGs are ad-hoc screenshots; intentional doc assets live in docs/.
/claude_plan_*.md
/claude_review_*.md
/codex_prompt*.md
/conflicts.md
/*.png
/openresearch.db.corrupt-*
/reprolab.db.corrupt-*

# Playwright MCP screenshot artifacts
.playwright-mcp
.playwright-mcp/

# Bicep parameter files with real subscription IDs — MUST NOT be committed.
# Copy from *.bicepparam.example and fill locally; never commit the filled copy.
infra/azure/bicep/main.bicepparam
# Terraform state — MUST NOT be committed (can carry resource metadata / secrets).
# Bootstrap state is written to infra/azure/bootstrap/terraform.tfstate after
# `terraform apply`; both it and any root-level state must stay local or in the
# remote backend configured via backend.hcl, never in git.
infra/azure/bootstrap/terraform.tfstate
*.tfstate
*.tfstate.backup
infra/azure/**/.terraform/
infra/gcp/**/.terraform/
# Operator env config — project ids, operator emails, egress IPs, bucket names.
# NEVER commit; the *.example templates stay tracked (different filename).
infra/gcp/envs/**/main.tfvars
infra/gcp/envs/**/backend.hcl
infra/gcp/envs/**/helm-values.yaml
infra/azure/envs/**/main.tfvars
infra/azure/envs/**/backend.hcl

# DeepEval runtime cache (deepeval is a real dep — cache repopulates as needed)
.deepeval
.deepeval/

# Landing-page exploration artifact (figma/AI export). Canonical mockups
# live in docs/idealui/; this dir is local working state, not source.
/LANDING/

# Stale "output" snapshots — committed once as test inputs, never referenced.
# Recreate via the live test suite if needed.
/runs_e2e_local/
/runs_e2e_docker/

# Landing screenshot scratch dir
frontend/tmp-screens
frontend/tmp-screens/
/playwright/

# Runtime-mutated artifacts (the code recreates/regenerates all of these;
# tracking them meant permanent dirty-tree churn — audit 2026-06-09)
/findings/*.log
/data/calibration.json
# Next.js regenerates next-env.d.ts on dev/build (dev vs build variants
# differ, so a tracked copy churns on every workflow switch)
frontend/next-env.d.ts

# Local architecture tutorials (not committed)
/docs/local/

# DeepInvent GCP VM provisioners — local-only operator scripts for the deferred
# SDAR smoke run; off-topic for this branch. Kept local so a `git add -A` can't
# sweep them into an unrelated PR. Force-add (`git add -f`) onto a proper branch
# when they're ready to ship.
/scripts/deepinvent_vm_*.sh

# Local-only GCP project notes — keep on disk, never publish (history purged 2026-06-18)
/gcp_info.md
