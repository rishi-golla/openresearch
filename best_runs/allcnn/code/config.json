{
  "_paper": "Striving for Simplicity: The All Convolutional Net (arXiv 1412.6806)",
  "_authors": "Springenberg et al., 2014",
  "_assumption_ids_applied": ["A001", "A002", "ENV001", "ENV002", "ENV-RT1"],

  "lr": 0.05,
  "_lr_note": "A001: fixed lr=0.05 for all cells; proven working (prj_0a3202fc187bb692-8f7fe95e). LR probe unreliable for AllCNN/ConvPool (probe_acc~10% for all LRs).",
  "momentum": 0.9,
  "weight_decay": 0.001,
  "epochs": 350,
  "batch_size": 128,
  "lr_milestones": [200, 250, 300],
  "lr_gamma": 0.1,
  "seed": 42,

  "use_zca": true,
  "_zca_note": "A002: GCN (scale=55, per Goodfellow et al. 2013) + ZCA whitening (epsilon=0.1)",
  "zca_epsilon": 0.1,
  "gcn_scale": 55.0,

  "augmentation": {
    "cifar10": {"horizontal_flip": true, "random_crop_padding": 5},
    "_note": "Used only for aug cells (c_allcnn_aug, c_allcnn_cifar100)"
  },

  "clip_grad_norm": 1.0,
  "_clip_note": "ENV-RT1: gradient clipping, proven stable in prior run",

  "init": "kaiming_normal_fan_out",
  "_init_note": "ENV002: kaiming_normal fan_out mode — critical for CIFAR-100 (100 classes)",

  "dropout_input": 0.2,
  "dropout_pool": 0.5,

  "expected_results_paper": {
    "All-CNN-C_cifar10_noaug": {"test_error_pct": 9.08},
    "All-CNN-C_cifar10_aug": {"test_error_pct": 7.25},
