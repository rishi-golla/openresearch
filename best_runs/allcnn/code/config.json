{
  "paper": "Striving for Simplicity: The All Convolutional Net",
  "authors": "Springenberg, Dosovitskiy, Brox, Riedmiller",
  "venue": "ICLR 2015 Workshop",
  "arxiv": "1412.6806",

  "cifar_training": {
    "optimizer": "SGD",
    "momentum": 0.9,
    "weight_decay": 0.001,
    "n_epochs": 350,
    "batch_size": 128,
    "lr_schedule_milestones": [200, 250, 300],
    "lr_gamma": 0.1,
    "lr_candidates": [0.25, 0.1, 0.05, 0.01],
    "dropout_input": 0.2,
    "dropout_pool": 0.5
  },

  "imagenet_training": {
    "optimizer": "SGD",
    "momentum": 0.9,
    "weight_decay": 0.0005,
    "n_iterations": 450000,
    "batch_size": 64,
    "initial_lr": 0.01,
    "lr_decay_factor": 10,
    "lr_decay_every_iterations": 200000,
    "evaluation": "center_224x224_crop"
  },

  "preprocessing": {
    "gcn": true,
    "gcn_scale": 55.0,
    "zca_whitening": true,
    "zca_eps": 0.1,
    "cifar10_normalize_mean": [0.4914, 0.4822, 0.4465],
    "cifar10_normalize_std": [0.2470, 0.2435, 0.2616]
  },

  "augmentation": {
    "horizontal_flip": true,
    "max_translation_pixels": 5,
    "note": "Pad with 5 pixels on each side, random crop back to 32x32"
  },

  "cifar_architectures": {
    "note": "12 variants: 3 base models x 4 pool modes",
    "base_models": {
      "A": "5x5 spatial convolutions",
      "B": "NiN: 5x5 + 1x1 after each spatial conv",
      "C": "Two stacked 3x3 replace each 5x5"
    },
    "pool_modes": {
      "base": "Standard max-pooling (3x3, stride=2)",
      "strided": "Last spatial conv has stride=2 (absorbs pool, same params as base)",
      "convpool": "Extra 3x3 conv before pool (adds params, keeps pool)",
      "allcnn": "Extra 3x3 stride=2 conv replaces pool (same params as convpool)"
    },
    "stage_channels": {
      "stage1_in": 3,
      "stage1_out": 96,
      "stage2_in": 96,
      "stage2_out": 192,
      "stage3_final": [192, 192, "num_classes"]
    },
    "dropout": {
      "input": 0.2,
      "after_each_pool": 0.5
    }
  },

  "imagenet_architecture": {
    "name": "All-CNN-B",
    "n_layers": 12,
    "layer_names": ["conv1", "conv2", "conv3", "conv4", "conv5", "conv6",
                    "conv7", "conv8", "conv9", "conv10", "conv11", "conv12"],
    "conv1": {"filters": 96, "kernel": 11, "stride": 4},
    "conv2": {"filters": 96, "kernel": 1, "stride": 1},
    "conv3": {"filters": 96, "kernel": 3, "stride": 2, "role": "pool_replacement"},
    "conv4": {"filters": 256, "kernel": 5, "stride": 1, "padding": 2},
    "conv5": {"filters": 256, "kernel": 1, "stride": 1},
    "conv6": {"filters": 256, "kernel": 3, "stride": 2, "role": "pool_replacement"},
    "conv7": {"filters": 384, "kernel": 3, "stride": 1, "padding": 1},
    "conv8": {"filters": 384, "kernel": 1, "stride": 1},
    "conv9": {"filters": 384, "kernel": 3, "stride": 2, "role": "pool_replacement"},
    "conv10": {"filters": 1024, "kernel": 3, "stride": 1, "padding": 0, "note": "valid"},
    "conv11": {"filters": 1024, "kernel": 1, "stride": 1},
    "conv12": {"filters": 1000, "kernel": 1, "stride": 1},
    "global_avg_pool": true
  },

  "guided_backprop": {
    "description": "Combines deconvnet and standard backprop masks at each ReLU",
    "rule": "zero an entry if top_gradient < 0 OR bottom_activation < 0",
    "formula": "guided_grad = incoming_grad * (incoming_grad > 0) * (forward_act > 0)"
  },

  "assumptions_applied": ["A001", "A002", "A003", "A004", "A005", "A006", "ENV001", "ENV002"]
}
