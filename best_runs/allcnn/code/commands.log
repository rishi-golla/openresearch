# commands.log — All-CNN Reproduction (prj_0a3202fc187bb692)
# Paper: "Striving for Simplicity: The All Convolutional Net" (arXiv 1412.6806)
# Generated: 2026-06-10

# ── Smoke test (sanity check, ~2min) ──────────────────────────────────────────
REPROLAB_SMOKE_STEPS=2 \
OUTPUT_DIR="$OUTPUT_DIR" \
  python /code/train.py --smoke-test 2>&1 | tee "$OUTPUT_DIR/smoke_test.log"

# ── Full training run (all 14 cells, ~8-10h on 2×GPU) ─────────────────────────
# Each cell: 350 epochs, SGD lr=0.05, momentum=0.9, wd=0.001
# LR schedule: ×0.1 at epochs [200, 250, 300]
# ZCA whitening: GCN (scale=55) + ZCA (ε=0.1)
OUTPUT_DIR="$OUTPUT_DIR" \
  python /code/train.py \
    --cells /code/cells.json \
    --config /code/config.json \
    2>&1 | tee "$OUTPUT_DIR/train.log"

# ── Single-cell manual run (for debugging) ────────────────────────────────────
# Example: run only All-CNN-C on CIFAR-10 (no augmentation)
REPROLAB_CELL_PARAMS='{"id":"c_allcnn_cifar10_noaug","model_key":"c_allcnn","letter":"C","variant":"allcnn","dataset":"cifar10","num_classes":10,"augment":false,"lr":0.05,"epochs":350,"batch_size":128,"seed":42,"use_zca":true}' \
REPROLAB_CELL_OUTPUT_DIR="$OUTPUT_DIR/cells/c_allcnn_cifar10_noaug" \
OUTPUT_DIR="$OUTPUT_DIR" \
  python /code/train_cell.py \
    2>&1 | tee "$OUTPUT_DIR/cells/c_allcnn_cifar10_noaug/cell.log"

# ── Verify metrics output ─────────────────────────────────────────────────────
# Expected: cifar10.final_test_accuracy ≈ 0.9032 (error ~9.68%)
#           cifar10.final_train_loss ≈ 0.05–0.15
python -c "import json; m=json.load(open('$OUTPUT_DIR/metrics.json')); print(json.dumps(m.get('cifar10',{}), indent=2))"

# ── Check per-model results ───────────────────────────────────────────────────
python -c "
import json
m = json.load(open('$OUTPUT_DIR/metrics.json'))
pm = m.get('per_model', {})
for k in sorted(pm.keys()):
    v = pm[k]
    err = v.get('test_error_pct','?')
    print(f'{k:30s}  test_error={err}%  status={v.get(\"status\",\"?\")}')
"
