{
  "paper": "Kingma & Ba (2014) Adam: A Method for Stochastic Optimization",
  "arxiv_id": "1412.6980",
  "assumptions_applied": ["ENV001", "ENV002", "ENV003"],

  "adam": {
    "lr": 0.001,
    "betas": [0.9, 0.999],
    "eps": 1e-8,
    "comment": "Algorithm 1 defaults from Section 2 caption"
  },
  "adamax": {
    "lr": 0.002,
    "betas": [0.9, 0.999],
    "comment": "Algorithm 2 defaults from Section 7.1"
  },
  "sgd_nesterov": {
    "lr": 0.01,
    "momentum": 0.9
  },
  "adagrad": {
    "lr": 0.01,
    "eps": 1e-8
  },
  "rmsprop": {
    "lr": 0.001,
    "rho": 0.9,
    "eps": 1e-8
  },
  "adadelta": {
    "rho": 0.95,
    "eps": 1e-6
  },

  "lr_grid_adam": [0.0001, 0.001, 0.003],
  "lr_grid_sgd":  [0.001, 0.01, 0.1],
  "lr_grid_ada":  [0.001, 0.01, 0.1],
  "momentum_grid": [0.5, 0.9],

  "mnist_lr": {
    "batch_size": 128,
    "iterations_cpu": 300,
    "iterations_gpu": 2000,
    "weight_decay": 1e-5,
    "stepsize_decay": "1/sqrt(t)",
    "comment": "Section 6.1 — MNIST multi-class logistic regression"
  },
  "imdb_lr": {
    "batch_size": 128,
    "iterations_cpu": 100,
    "iterations_gpu": 500,
    "n_words": 10000,
    "dropout_input": 0.5,
    "weight_decay": 1e-5,
    "stepsize_decay": "1/sqrt(t)",
    "comment": "Section 6.1 — IMDB BoW sparse logistic regression"
  },
  "mlp_mnist": {
    "batch_size": 128,
    "hidden_size": 1000,
    "n_layers": 2,
    "dropout": 0.5,
    "weight_decay": 1e-5,
    "iterations_cpu": 300,
    "iterations_gpu": 2000,
    "comment": "Section 6.2 — 2-layer MLP with 1000 ReLU units each"
  },
  "cifar10_cnn": {
    "batch_size": 128,
    "epochs_cpu": 3,
    "epochs_gpu": 45,
    "dropout_input": 0.2,
    "dropout_fc": 0.5,
    "comment": "Section 6.3 — c64-c64-c128-1000 ConvNet, 45 epochs"
  },
  "vae_mnist": {
    "batch_size": 100,
    "latent_dim": 20,
    "hidden_dim": 400,
    "epochs_cpu": 5,
    "epochs_gpu": 100,
    "comment": "Section 6.4 — VAE bias-correction comparison"
  },

  "seed": 42
}
