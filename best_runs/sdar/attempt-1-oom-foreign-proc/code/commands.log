## Installation (auto-installed by harness from requirements.txt)
pip install -r requirements.txt

## Smoke test (SMOKE=1: 5 steps, tiny eval, ~2 min on GPU)
## VALIDATED: passes RubricGuard ✓, non-zero rewards ✓
SMOKE=1 python train.py --output-dir $OUTPUT_DIR

## Full run — all models, all environments, all algorithms (150 steps each)
## Expected duration: ~12-20 hours on a single 24+ GB GPU
python train.py --output-dir $OUTPUT_DIR

## Smallest-two scope (recommended for cost-bounded runs: 1.7B + 3B only)
python train.py --models qwen3_1_7b qwen2_5_3b --output-dir $OUTPUT_DIR

## Single model run (fastest for debugging)
python train.py --models qwen3_1_7b --output-dir $OUTPUT_DIR

## Search-QA only (fastest env — skip ALFWorld and WebShop)
python train.py --envs search_qa --output-dir $OUTPUT_DIR

## SDAR vs GRPO comparison only (2 algorithms, fastest comparison)
python train.py --algorithms sdar grpo --output-dir $OUTPUT_DIR

## With ablations (beta/lambda/gate/retrieval sweeps on 3B × search_qa)
python train.py --ablations --output-dir $OUTPUT_DIR

## Without ablations (main table only)
python train.py --no-ablations --output-dir $OUTPUT_DIR

