# Keep the build context small. Anything here is invisible to `docker build`.

# Python
.venv/
venv/
backend/venv/
**/__pycache__/
**/*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Node / Next
**/node_modules/
frontend/tsconfig.tsbuildinfo
# **/.next/ (not bare .next/): the stale 15MB frontend/.next was entering
# every build context — stage 2 rebuilds it anyway.
**/.next/

# Local state
.env
.env.*
!.env.example
runs/
logs/
_test_logs/
*.db
*.db-*
openresearch.db.*

# Non-runtime artifacts (docs/media never used inside the image; the two
# root PDFs MUST stay in-context — they are runtime fixtures, live_runs.py)
paper-repro-bes-docs/
findings/
best_runs/

# Tooling / VCS
.git/
.github/
.vscode/
.idea/
.DS_Store
.codex/
.claude/

# Working / transient docs
claude_plan_*.md
claude_review_*.md
codex_prompt_*.md
conflicts.md
*:Zone.Identifier

# Compose / extra Dockerfiles aren't needed inside the build context, but
# the active Dockerfile + docker/ MUST stay reachable so the COPY succeeds.
docker-compose*.yml
