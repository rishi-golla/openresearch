# Verify algorithmic invariants
/home/sww35/openresearch/.venv/bin/python -c "
from sdar.algorithms import BETA, LAMBDA; assert BETA==10.0; assert LAMBDA==0.1
from sdar.gating import GapGating
import torch; lp_s = torch.randn(4, requires_grad=True)
gate = GapGating(beta=BETA)(torch.randn(4), lp_s)
assert not gate.requires_grad  # stop-gradient
print('Invariants: BETA=10 LAMBDA=0.1 stop-gradient OK')
"

